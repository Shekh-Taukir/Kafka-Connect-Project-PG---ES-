{
  "name": "elastic_search-sink-v1",
  "config": {
    "connector.class": "io.confluent.connect.elasticsearch.ElasticsearchSinkConnector",
    "tasks.max": "1",
    "topics": "st_dept_enriched",

    "schema.ignore": "true",
    "_comment-behavior.on.null.values": "ignore",
    "_comment-write.method": "insert",

    "connection.url": "http://192.168.0.4:9200",
    "_comment-connection.username": "elastic",
    "_comment-connection.password": "zeeshan",

    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "_comment-key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "key.ignore": "true",

    "_comment-validate.indices.exists": "false",
    "-comment-use.data.stream": "false",
    "behavior.on.malformed.documents": "warn",

    "auto.create.indices.at.start": "false",
    "_comment-connection.timeout.ms": "10000",
    "_comment-read.timeout.ms": "10000",
    "auto.offset.reset": "earliest",

    "_comment-elastic.security.protocol": "SSL",
    "_comment-elastic.https.ssl.truststore.location": "",
    "_comment-elastic.https.ssl.type": "none",

    "_comment-transforms": "lowercaseIndex",
    "_comment-transforms.lowercaseIndex.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "_comment-transforms.lowercaseIndex.replacement": "st_dept_enriched",
    "_comment-transforms.lowercaseIndex.regex": ".*",

    "batch.size": "1",

    "errors.log.enable": "true"
  }
}
