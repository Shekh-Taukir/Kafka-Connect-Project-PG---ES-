{
  "name": "es_sink_conn_data_2_policy_new_v1",
  "config": {
    "connector.class": "io.confluent.connect.elasticsearch.ElasticsearchSinkConnector",
    "tasks.max": "1",
    "topics": "kt_dbz_policies_proc_json_sr",
	"index":"es_idx_data_2_policy_new",
	
	"topic.map.index":"kt_dbz_policies_proc_json_sr:es_idx_data_2_policy_new",

    "schema.ignore": "false",

    "connection.url": "http://192.168.0.4:9200",

    "value.converter": "io.confluent.connect.json.JsonSchemaConverter",
    "value.converter.schemas.enable": "false",
	"value.converter.schema.registry.url":"http://localhost:8081",
	
	"key.converter":"io.confluent.connect.json.JsonSchemaConverter",
	"key.converter.schema.registry.url":"http://localhost:8081",
	
    "_comment_old_key.converter":"org.apache.kafka.connect.storage.StringConverter",
    "key.ignore": "false",
	
	"write.method":"upsert",
    
    "behavior.on.malformed.documents": "warn",
	"behavior.on.null.values": "IGNORE",
	
	"transforms": "createKey,extractKey",
	"transforms.createKey.type": "org.apache.kafka.connect.transforms.ValueToKey",
	"transforms.createKey.fields": "tran_id",
	
	"transforms.extractKey.type": "org.apache.kafka.connect.transforms.ExtractField$Key",
	"transforms.extractKey.field": "tran_id",

    "auto.create.indices.at.start": "false",
    "auto.offset.reset": "earliest",

	"drop.invalid.message": "true",
    "batch.size": "1",

    "errors.log.enable": "true"
  }
}
